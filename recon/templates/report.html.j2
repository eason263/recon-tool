<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>recon report — {{ r.a_name }} vs {{ r.b_name }}</title>
<style>
  body { font-family: -apple-system, "Segoe UI", Helvetica, Arial, sans-serif; margin: 24px; color: #1f2328; }
  h1 { font-size: 20px; } h2 { font-size: 16px; margin-top: 28px; }
  .meta { color: #59636e; font-size: 13px; margin-bottom: 20px; }
  .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 13px; font-weight: 600; }
  .badge.ok { background: #dafbe1; color: #116329; }
  .badge.bad { background: #ffebe9; color: #cf222e; }
  table { border-collapse: collapse; width: 100%; font-size: 13px; }
  th, td { border: 1px solid #d1d9e0; padding: 4px 8px; text-align: left; vertical-align: top; }
  th { background: #f6f8fa; }
  .summary table { width: auto; min-width: 320px; }
  .diff td.code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; white-space: pre-wrap; word-break: break-all; width: 46%; }
  .diff td.lineno { color: #59636e; text-align: right; width: 4%; background: #f6f8fa; font-family: ui-monospace, monospace; }
  tr.insert td.right { background: #dafbe1; }
  tr.delete td.left { background: #ffebe9; }
  tr.replace td.left { background: #fff1c2; }
  tr.replace td.right { background: #fff1c2; }
  td.a-val { background: #ffebe9; } td.b-val { background: #dafbe1; }
  td.status-bad { color: #cf222e; font-weight: 700; } td.status-ok { color: #59636e; }
  tr.record-start td { border-top: 2px solid #8c959f; }
  .back { margin-bottom: 16px; font-size: 14px; }
</style>
</head>
<body>
{% if back_url %}<div class="back"><a href="{{ back_url }}">← New comparison</a></div>{% endif %}
<h1>Comparison report
{% if mode == "diff" %}
  {% if r.identical %}<span class="badge ok">identical</span>{% else %}<span class="badge bad">differences found</span>{% endif %}
{% else %}
  {% if r.reconciled %}<span class="badge ok">fully reconciled</span>{% else %}<span class="badge bad">differences found</span>{% endif %}
{% endif %}
</h1>
<div class="meta">
  A: <strong>{{ r.a_name }}</strong> &nbsp;·&nbsp; B: <strong>{{ r.b_name }}</strong> &nbsp;·&nbsp; generated {{ generated }}
</div>

{% if mode == "diff" %}
  {% if not r.identical %}
  <div class="summary">
    <table>
      <tr><th>Added lines</th><td>{{ r.added }}</td></tr>
      <tr><th>Removed lines</th><td>{{ r.removed }}</td></tr>
      <tr><th>Changed lines</th><td>{{ r.changed }}</td></tr>
    </table>
  </div>
  <h2>Side-by-side diff</h2>
  <table class="diff">
    <tr><th></th><th>{{ r.a_name }}</th><th></th><th>{{ r.b_name }}</th></tr>
    {% for row in r.rows %}
    <tr class="{{ row.tag }}">
      <td class="lineno">{{ row.left_no if row.left_no else "" }}</td>
      <td class="code left">{{ row.left }}</td>
      <td class="lineno">{{ row.right_no if row.right_no else "" }}</td>
      <td class="code right">{{ row.right }}</td>
    </tr>
    {% endfor %}
  </table>
  {% endif %}

{% else %}
  <div class="summary">
    <table>
      <tr><th>Key columns</th><td>{{ r.key_columns | join(", ") }}</td></tr>
      <tr><th>Records in A</th><td>{{ r.total_a }}</td></tr>
      <tr><th>Records in B</th><td>{{ r.total_b }}</td></tr>
      <tr><th>Matched keys</th><td>{{ r.matched }}</td></tr>
      <tr><th>Keys with mismatched fields</th><td>{{ r.mismatched_keys | length }}</td></tr>
      <tr><th>Only in A</th><td>{{ r.only_in_a | length }}</td></tr>
      <tr><th>Only in B</th><td>{{ r.only_in_b | length }}</td></tr>
      <tr><th>Duplicate keys (A / B)</th><td>{{ r.duplicate_keys_a | length }} / {{ r.duplicate_keys_b | length }}</td></tr>
    </table>
  </div>

  {% if r.mismatches and show_matched %}
  <h2>Mismatched records — all fields ({{ r.mismatched_keys | length }} records)</h2>
  <table>
    <tr><th>Key</th><th>Column</th><th>{{ r.a_name }}</th><th>{{ r.b_name }}</th><th>Status</th></tr>
    {% for k in r.mismatched_keys %}
      {% for c in r.compared_columns %}
      {% set bad = (k, c) in mismatch_set %}
      <tr{% if loop.first %} class="record-start"{% endif %}>
        <td>{% if loop.first %}{{ fmt_key(k) }}{% endif %}</td>
        <td>{{ c }}</td>
        <td{% if bad %} class="a-val"{% endif %}>{{ r.records_a[k].get(c) or "" }}</td>
        <td{% if bad %} class="b-val"{% endif %}>{{ r.records_b[k].get(c) or "" }}</td>
        {% if bad %}<td class="status-bad">✗</td>{% else %}<td class="status-ok">✓</td>{% endif %}
      </tr>
      {% endfor %}
    {% endfor %}
  </table>
  {% elif r.mismatches %}
  <h2>Field mismatches ({{ r.mismatches | length }})</h2>
  <table>
    <tr><th>Key</th><th>Column</th><th>{{ r.a_name }}</th><th>{{ r.b_name }}</th></tr>
    {% for m in r.mismatches %}
    <tr><td>{{ fmt_key(m.key) }}</td><td>{{ m.column }}</td><td class="a-val">{{ m.a_value }}</td><td class="b-val">{{ m.b_value }}</td></tr>
    {% endfor %}
  </table>
  {% endif %}

  {% for label, keys, records in [("Only in " ~ r.a_name, r.only_in_a, r.records_a), ("Only in " ~ r.b_name, r.only_in_b, r.records_b)] %}
    {% if keys %}
    <h2>{{ label }} ({{ keys | length }})</h2>
    <table>
      <tr><th>Key</th>{% for c in r.compared_columns %}<th>{{ c }}</th>{% endfor %}</tr>
      {% for k in keys %}
      <tr><td>{{ fmt_key(k) }}</td>{% for c in r.compared_columns %}<td>{{ records[k].get(c) or "" }}</td>{% endfor %}</tr>
      {% endfor %}
    </table>
    {% endif %}
  {% endfor %}

  {% for label, keys in [("Duplicate keys in " ~ r.a_name, r.duplicate_keys_a), ("Duplicate keys in " ~ r.b_name, r.duplicate_keys_b)] %}
    {% if keys %}
    <h2>{{ label }} ({{ keys | length }})</h2>
    <p>{% for k in keys %}{{ fmt_key(k) }}{% if not loop.last %}, {% endif %}{% endfor %}</p>
    {% endif %}
  {% endfor %}
{% endif %}
</body>
</html>
