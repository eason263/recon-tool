{% extends "_base.html.j2" %}
{% block title %}Compare{% endblock %}

{% block content %}
<div class="top-bar">
  <div class="breadcrumb">
    <span class="cur">Compare files</span>
  </div>
  <div class="top-bar-right">
    <a href="/batch" class="btn btn-ghost btn-sm">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
      Batch mode
    </a>
  </div>
</div>

<div class="content" style="max-width:620px;">
  <div class="ph">
    <div class="ph-left">
      <h1>Compare &amp; reconcile</h1>
      <div class="sub">Upload two files to diff or reconcile them record-by-record. For tabular data (CSV/XLSX), specify key columns to get a structured break report.</div>
    </div>
  </div>

  {% if error %}
  <div class="alert alert-err">{{ error }}</div>
  {% endif %}

  <div class="card">
    <div class="card-head"><span class="card-title">File upload</span></div>
    <div class="card-body">
      <form method="post" action="/compare" enctype="multipart/form-data">
        <div class="fg">
          <label class="fl" for="fa">File A</label>
          <input id="fa" type="file" name="file_a" required>
        </div>
        <div class="fg">
          <label class="fl" for="fb">File B</label>
          <input id="fb" type="file" name="file_b" required>
        </div>

        <fieldset class="fieldset">
          <legend>Reconciliation options — CSV / XLSX only</legend>
          <div class="fg" style="margin-top:10px;">
            <label class="fl" for="key">Key column(s)</label>
            <input id="key" type="text" name="key" placeholder="e.g. trade_id  or  id,date" value="{{ form.get('key', '') }}">
            <div class="fh">Comma-separated. Leave empty for a plain text diff.</div>
          </div>
          <div class="fg">
            <label class="fl" for="ignore">Ignore columns</label>
            <input id="ignore" type="text" name="ignore" placeholder="e.g. updated_at,internal_ref" value="{{ form.get('ignore', '') }}">
          </div>
          <div class="fg" style="max-width:200px;">
            <label class="fl" for="tol">Numeric tolerance</label>
            <input id="tol" type="number" name="tolerance" step="any" min="0" placeholder="0" value="{{ form.get('tolerance', '') }}">
          </div>
          <label class="check-row">
            <input type="checkbox" name="show_matched" value="1" {% if form.get('show_matched') %}checked{% endif %}>
            Show all fields of mismatched records (including matched fields)
          </label>
        </fieldset>

        <div style="margin-top:20px;">
          <button class="btn btn-primary" type="submit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Run comparison
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}
