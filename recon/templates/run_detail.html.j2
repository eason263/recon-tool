{% extends "_base.html.j2" %}
{% block title %}Run #{{ run.id }}{% endblock %}

{% block content %}
<div class="top-bar">
  <div class="breadcrumb">
    <a href="/runs">Run history</a>
    <span class="sep">/</span>
    <span class="cur">Run #{{ run.id }}</span>
  </div>
  <div class="top-bar-right">
    <a href="/runs/{{ run.id }}/export?format=csv" class="btn btn-ghost btn-sm">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export CSV
    </a>
    <a href="/runs/{{ run.id }}/export?format=json" class="btn btn-ghost btn-sm">JSON</a>
  </div>
</div>

<div class="content">
  <div class="ph">
    <div class="ph-left">
      <h1>
        {{ run.job_name }}
        <span class="badge status-{{ run.status }}" style="font-size:13px;vertical-align:middle;margin-left:6px;">{{ run.status }}</span>
      </h1>
      <div class="sub">{{ run.source }} → {{ run.target }} &nbsp;·&nbsp; {{ run.ran_at }}</div>
    </div>
  </div>

  <div class="stats">
    <div class="stat"><div class="v">{{ run.total_a }}</div><div class="l">Records A</div></div>
    <div class="stat"><div class="v">{{ run.total_b }}</div><div class="l">Records B</div></div>
    <div class="stat"><div class="v" style="color:var(--green);">{{ run.matched }}</div><div class="l">Matched</div></div>
    <div class="stat"><div class="v" style="color:{% if run.mismatches > 0 %}var(--amber){% else %}var(--text3){% endif %};">{{ run.mismatches }}</div><div class="l">Field diffs</div></div>
    <div class="stat"><div class="v" style="color:{% if run.only_in_a > 0 %}var(--red){% else %}var(--text3){% endif %};">{{ run.only_in_a }}</div><div class="l">Only in A</div></div>
    <div class="stat"><div class="v" style="color:{% if run.only_in_b > 0 %}var(--blue){% else %}var(--text3){% endif %};">{{ run.only_in_b }}</div><div class="l">Only in B</div></div>
  </div>

  {% set visible = breaks if not status_filter else breaks | selectattr('status', 'equalto', status_filter) | list %}
  {% set n_open = breaks | selectattr('status','equalto','open')           | list | length %}
  {% set n_res  = breaks | selectattr('status','equalto','resolved')       | list | length %}
  {% set n_fp   = breaks | selectattr('status','equalto','false_positive') | list | length %}

  <div class="filter-bar" style="margin-bottom:16px;">
    <span class="filter-lbl">Filter:</span>
    <a href="/runs/{{ run.id }}" class="pill {% if not status_filter %}active{% endif %}">All ({{ breaks|length }})</a>
    <a href="/runs/{{ run.id }}?status=open" class="pill {% if status_filter == 'open' %}active{% endif %}">
      Open{% if n_open %} <span style="font-weight:700;">{{ n_open }}</span>{% endif %}
    </a>
    <a href="/runs/{{ run.id }}?status=resolved" class="pill {% if status_filter == 'resolved' %}active{% endif %}">Resolved{% if n_res %} {{ n_res }}{% endif %}</a>
    <a href="/runs/{{ run.id }}?status=false_positive" class="pill {% if status_filter == 'false_positive' %}active{% endif %}">False positive{% if n_fp %} {{ n_fp }}{% endif %}</a>
  </div>

  {% if visible %}
  <div class="tbl-wrap">
    <table>
      <thead>
        <tr>
          <th>Type</th>
          <th>Key</th>
          <th>Column</th>
          <th>A value</th>
          <th>B value</th>
          <th>Status</th>
          <th>Assigned</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for b in visible %}
        <tr>
          <td><span class="badge bt-{{ b.break_type }}">{{ b.break_type.replace('_', ' ') }}</span></td>
          <td class="mono" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{ b.key_display }}">{{ b.key_display }}</td>
          <td>{{ b.column or '<span style="color:var(--text3);">—</span>' }}</td>
          <td><span class="va">{{ b.a_value if b.a_value is not none else '' }}</span></td>
          <td><span class="vb">{{ b.b_value if b.b_value is not none else '' }}</span></td>
          <td class="bs-{{ b.status }}">{{ b.status.replace('_', ' ') }}</td>
          <td style="color:var(--text2);">{{ b.assigned_to or '<span style="color:var(--text3);">—</span>' }}</td>
          <td><a href="/runs/{{ run.id }}/breaks/{{ b.id }}" class="link" style="white-space:nowrap;">Manage →</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="empty">
    <h3>No breaks match this filter</h3>
    <p>Try a different filter above.</p>
  </div>
  {% endif %}
</div>
{% endblock %}
