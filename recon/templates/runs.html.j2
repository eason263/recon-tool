{% extends "_base.html.j2" %}
{% block title %}Run history{% endblock %}

{% block content %}
<div class="top-bar">
  <div class="breadcrumb">
    <span class="cur">Run history</span>
  </div>
  <div class="top-bar-right">
    <a href="/" class="btn btn-primary btn-sm">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New comparison
    </a>
  </div>
</div>

<div class="content">
  {% if runs %}
  {% set total = runs|length %}
  {% set n_match = runs|selectattr('status','equalto','MATCH')|list|length %}
  {% set n_diff  = runs|selectattr('status','equalto','DIFF') |list|length %}
  {% set n_err   = runs|selectattr('status','equalto','ERROR')|list|length %}

  <div class="stats">
    <div class="stat"><div class="v">{{ total }}</div><div class="l">Total runs</div></div>
    <div class="stat"><div class="v" style="color:var(--green);">{{ n_match }}</div><div class="l">Clean</div></div>
    <div class="stat"><div class="v" style="color:var(--amber);">{{ n_diff }}</div><div class="l">With breaks</div></div>
    {% if n_err %}<div class="stat"><div class="v" style="color:var(--red);">{{ n_err }}</div><div class="l">Errors</div></div>{% endif %}
  </div>

  <div class="tbl-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Job</th>
          <th>Source</th>
          <th>Target</th>
          <th>Status</th>
          <th>Matched</th>
          <th>Breaks</th>
          <th>Run at</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for r in runs %}
        <tr>
          <td class="mono" style="color:var(--text3);">{{ r.id }}</td>
          <td style="font-weight:500;">{{ r.job_name }}</td>
          <td class="mono" style="color:var(--text2);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{ r.source }}">{{ r.source }}</td>
          <td class="mono" style="color:var(--text2);max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="{{ r.target }}">{{ r.target }}</td>
          <td><span class="badge status-{{ r.status }}">{{ r.status }}</span></td>
          <td>{{ r.matched }} / {{ r.total_a }}</td>
          <td>
            {% set breaks = r.mismatches + r.only_in_a + r.only_in_b %}
            {% if breaks > 0 %}<span style="font-weight:600;color:var(--amber);">{{ breaks }}</span>{% else %}<span style="color:var(--text3);">0</span>{% endif %}
          </td>
          <td style="color:var(--text2);white-space:nowrap;">{{ r.ran_at }}</td>
          <td><a href="/runs/{{ r.id }}" class="link">View</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="empty">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    <h3>No runs yet</h3>
    <p>Run a <a href="/" class="link">comparison</a> to get started.</p>
  </div>
  {% endif %}
</div>
{% endblock %}
