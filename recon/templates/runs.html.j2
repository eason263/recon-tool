<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>recon · run history</title>
<style>
  body { font-family: -apple-system, "Segoe UI", Helvetica, Arial, sans-serif; margin: 0; color: #1f2328; }
  .nav { background: #fff; border-bottom: 1px solid #d1d9e0; padding: 10px 24px; display: flex; align-items: center; gap: 20px; }
  .nav a { color: #1f2328; text-decoration: none; font-size: 14px; }
  .nav a:hover { color: #0969da; }
  .nav .brand { font-weight: 700; font-size: 16px; }
  .nav .logout { margin-left: auto; color: #59636e; }
  .content { padding: 24px; }
  h1 { font-size: 20px; margin: 0 0 20px; }
  table { border-collapse: collapse; width: 100%; font-size: 13px; }
  th, td { border: 1px solid #d1d9e0; padding: 6px 10px; text-align: left; }
  th { background: #f6f8fa; font-weight: 600; }
  tr:hover td { background: #f6f8fa; }
  .badge { display: inline-block; padding: 1px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; }
  .badge.MATCH { background: #dafbe1; color: #116329; }
  .badge.DIFF  { background: #fff1c2; color: #7d4e00; }
  .badge.ERROR { background: #ffebe9; color: #cf222e; }
  a { color: #0969da; }
  .empty { color: #59636e; margin-top: 40px; text-align: center; }
</style>
</head>
<body>
<nav class="nav">
  <span class="brand">recon</span>
  <a href="/">Compare</a>
  <a href="/batch">Batch</a>
  <a href="/runs">History</a>
  <a href="/logout" class="logout">Sign out ({{ user }})</a>
</nav>
<div class="content">
  <h1>Run history</h1>
  {% if runs %}
  <table>
    <tr>
      <th>#</th><th>Job</th><th>Source</th><th>Target</th>
      <th>Status</th><th>Matched</th><th>Breaks</th><th>Run at</th><th></th>
    </tr>
    {% for r in runs %}
    <tr>
      <td>{{ r.id }}</td>
      <td>{{ r.job_name }}</td>
      <td>{{ r.source }}</td>
      <td>{{ r.target }}</td>
      <td><span class="badge {{ r.status }}">{{ r.status }}</span></td>
      <td>{{ r.matched }} / {{ r.total_a }}</td>
      <td>{{ r.mismatches + r.only_in_a + r.only_in_b }}</td>
      <td>{{ r.ran_at }}</td>
      <td><a href="/runs/{{ r.id }}">view</a></td>
    </tr>
    {% endfor %}
  </table>
  {% else %}
  <div class="empty">No runs yet. <a href="/">Run a comparison</a> to get started.</div>
  {% endif %}
</div>
</body>
</html>
