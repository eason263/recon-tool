<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}recon{% endblock %}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root {
  --sw: 220px;
  --sb: #0F172A; --sb-border: rgba(255,255,255,0.07);
  --ni: #94A3B8; --na: #F8FAFC; --na-bg: rgba(255,255,255,0.09); --nh-bg: rgba(255,255,255,0.05);
  --bg: #F1F5F9; --surface: #fff; --surface2: #F8FAFC;
  --border: #E2E8F0; --border2: #CBD5E1;
  --text: #0F172A; --text2: #475569; --text3: #94A3B8;
  --blue: #2563EB; --blue-h: #1D4ED8; --blue-l: #EFF6FF;
  --green: #16A34A; --green-l: #DCFCE7; --green-d: #166534;
  --amber: #D97706; --amber-l: #FEF3C7; --amber-d: #92400E;
  --red: #DC2626; --red-l: #FEE2E2; --red-d: #991B1B;
  --font: 'IBM Plex Sans',-apple-system,sans-serif;
  --mono: 'IBM Plex Mono',Menlo,monospace;
  --r: 6px; --r-lg: 10px;
  --sh: 0 1px 3px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.05);
}

body { font-family:var(--font); font-size:14px; color:var(--text); background:var(--bg); line-height:1.5; }

.layout { display:flex; min-height:100vh; }

/* ── Sidebar ─────────────────────────────────────── */
.sidebar {
  width:var(--sw); min-height:100vh; background:var(--sb);
  display:flex; flex-direction:column;
  position:fixed; top:0; left:0; bottom:0; z-index:40;
  border-right:1px solid var(--sb-border);
}
.sb-logo {
  display:flex; align-items:center; gap:10px;
  padding:18px 16px 14px;
  border-bottom:1px solid var(--sb-border);
}
.sb-mark {
  width:28px; height:28px; background:var(--blue); border-radius:7px;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.sb-name { font-size:15px; font-weight:700; color:#F8FAFC; letter-spacing:-.02em; }
.sb-nav { flex:1; padding:8px; display:flex; flex-direction:column; gap:2px; overflow-y:auto; }
.sb-section {
  font-size:10px; font-weight:600; letter-spacing:.08em; text-transform:uppercase;
  color:rgba(148,163,184,.45); padding:12px 8px 4px;
}
.nav-item {
  display:flex; align-items:center; gap:10px; padding:7px 10px;
  border-radius:var(--r); color:var(--ni); text-decoration:none;
  font-size:13.5px; font-weight:450; transition:background 150ms,color 150ms; cursor:pointer;
}
.nav-item:hover { background:var(--nh-bg); color:#CBD5E1; }
.nav-item.active { background:var(--na-bg); color:var(--na); font-weight:500; }
.nav-item svg { flex-shrink:0; opacity:.7; }
.nav-item.active svg { opacity:1; }
.sb-foot { padding:10px 8px; border-top:1px solid var(--sb-border); }
.sb-user { display:flex; align-items:center; gap:8px; padding:7px 10px; }
.sb-avatar {
  width:26px; height:26px; background:rgba(255,255,255,.1); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:11px; font-weight:600; color:#CBD5E1; flex-shrink:0;
}
.sb-uname { font-size:13px; color:#94A3B8; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.sb-logout {
  display:flex; align-items:center; gap:9px; padding:7px 10px;
  border-radius:var(--r); color:rgba(148,163,184,.55); text-decoration:none;
  font-size:13px; transition:background 150ms,color 150ms;
}
.sb-logout:hover { background:var(--nh-bg); color:#94A3B8; }

/* ── Main ─────────────────────────────────────────── */
.main { margin-left:var(--sw); flex:1; display:flex; flex-direction:column; min-height:100vh; }
.top-bar {
  background:var(--surface); border-bottom:1px solid var(--border);
  padding:0 28px; height:50px; display:flex; align-items:center;
  position:sticky; top:0; z-index:30;
}
.breadcrumb { display:flex; align-items:center; gap:6px; font-size:13px; color:var(--text3); }
.breadcrumb a { color:var(--text3); text-decoration:none; }
.breadcrumb a:hover { color:var(--text2); }
.breadcrumb .sep { color:var(--border2); }
.breadcrumb .cur { color:var(--text); font-weight:500; }
.top-bar-right { margin-left:auto; display:flex; align-items:center; gap:8px; }
.content { padding:24px 28px; flex:1; }

/* ── Page header ──────────────────────────────────── */
.ph { display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:20px; }
.ph-left h1 { font-size:18px; font-weight:700; letter-spacing:-.02em; }
.ph-left .sub { font-size:13px; color:var(--text2); margin-top:2px; }

/* ── Stat tiles ──────────────────────────────────── */
.stats { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
.stat {
  background:var(--surface); border:1px solid var(--border);
  border-radius:var(--r-lg); padding:14px 18px; min-width:108px; box-shadow:var(--sh);
}
.stat .v { font-size:26px; font-weight:700; letter-spacing:-.03em; line-height:1.1; }
.stat .l { font-size:11px; color:var(--text3); margin-top:4px; font-weight:600; text-transform:uppercase; letter-spacing:.05em; }

/* ── Card ────────────────────────────────────────── */
.card { background:var(--surface); border:1px solid var(--border); border-radius:var(--r-lg); box-shadow:var(--sh); }
.card-head { padding:14px 20px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
.card-title { font-size:13.5px; font-weight:600; }
.card-body { padding:20px; }

/* ── Table ───────────────────────────────────────── */
.tbl-wrap { overflow-x:auto; border-radius:var(--r-lg); border:1px solid var(--border); background:var(--surface); box-shadow:var(--sh); }
table { width:100%; border-collapse:collapse; font-size:13px; }
thead th {
  background:var(--surface2); padding:9px 14px; text-align:left;
  font-size:11px; font-weight:700; color:var(--text3);
  text-transform:uppercase; letter-spacing:.06em;
  border-bottom:1px solid var(--border); white-space:nowrap;
}
tbody td { padding:10px 14px; border-bottom:1px solid var(--border); vertical-align:middle; }
tbody tr:last-child td { border-bottom:none; }
tbody tr:hover td { background:var(--surface2); }
.mono { font-family:var(--mono); font-size:12.5px; }

/* ── Badges ──────────────────────────────────────── */
.badge {
  display:inline-flex; align-items:center; gap:4px;
  padding:2px 8px; border-radius:100px; font-size:11.5px; font-weight:600; white-space:nowrap;
}
.b-green  { background:var(--green-l);  color:var(--green-d); }
.b-amber  { background:var(--amber-l);  color:var(--amber-d); }
.b-red    { background:var(--red-l);    color:var(--red-d); }
.b-blue   { background:var(--blue-l);   color:#1E40AF; }
.b-gray   { background:#F1F5F9;         color:#475569; }
.b-yellow { background:#FEF9C3;         color:#713F12; }

.status-MATCH { background:var(--green-l); color:var(--green-d); }
.status-DIFF  { background:var(--amber-l); color:var(--amber-d); }
.status-ERROR { background:var(--red-l);   color:var(--red-d); }

.bt-field_mismatch { background:#FEF9C3; color:#713F12; }
.bt-only_in_a      { background:var(--red-l);  color:var(--red-d); }
.bt-only_in_b      { background:var(--blue-l); color:#1E40AF; }

.bs-open           { color:var(--red);   font-weight:500; }
.bs-resolved       { color:var(--green); font-weight:500; }
.bs-false_positive { color:#64748B;      font-weight:500; }

/* ── Buttons ─────────────────────────────────────── */
.btn {
  display:inline-flex; align-items:center; gap:6px;
  padding:7px 14px; border-radius:var(--r); font-size:13.5px; font-weight:500;
  cursor:pointer; transition:background 150ms; text-decoration:none;
  border:none; font-family:var(--font); white-space:nowrap;
}
.btn-primary  { background:var(--blue);  color:#fff; }
.btn-primary:hover  { background:var(--blue-h); }
.btn-success  { background:var(--green); color:#fff; }
.btn-success:hover  { background:#15803D; }
.btn-danger   { background:var(--red);   color:#fff; }
.btn-danger:hover   { background:#B91C1C; }
.btn-ghost    { background:transparent;  color:var(--text2); border:1px solid var(--border); }
.btn-ghost:hover    { background:var(--surface2); }
.btn-sm { padding:4px 10px; font-size:12.5px; }

/* ── Forms ───────────────────────────────────────── */
.fg { margin-bottom:16px; }
.fl { display:block; font-size:13px; font-weight:500; color:var(--text); margin-bottom:5px; }
.fh { font-size:12px; color:var(--text3); margin-top:4px; }
input[type=text],input[type=password],input[type=number],input[type=email],
input[type=file],select,textarea {
  width:100%; padding:8px 12px; border:1px solid var(--border);
  border-radius:var(--r); font-size:13.5px; font-family:var(--font);
  color:var(--text); background:var(--surface);
  transition:border-color 150ms,box-shadow 150ms; outline:none;
}
input[type=file] { padding:6px 10px; cursor:pointer; }
input:focus,select:focus,textarea:focus {
  border-color:var(--blue); box-shadow:0 0 0 3px rgba(37,99,235,.1);
}
textarea { resize:vertical; min-height:80px; }
.fieldset { border:1px solid var(--border); border-radius:var(--r-lg); padding:16px; margin-bottom:16px; }
.fieldset legend {
  font-size:11.5px; font-weight:700; color:var(--text3);
  text-transform:uppercase; letter-spacing:.06em; padding:0 6px;
}
.check-row { display:flex; align-items:center; gap:8px; font-size:13px; color:var(--text2); cursor:pointer; margin-top:4px; }
.check-row input { width:auto; accent-color:var(--blue); }

/* ── Filter pills ────────────────────────────────── */
.filter-bar { display:flex; align-items:center; gap:6px; margin-bottom:14px; }
.filter-lbl { font-size:12px; color:var(--text3); font-weight:500; margin-right:2px; }
.pill {
  padding:4px 12px; border-radius:100px; font-size:12px; font-weight:500;
  text-decoration:none; color:var(--text2); background:var(--surface);
  border:1px solid var(--border); transition:all 150ms; cursor:pointer;
}
.pill:hover { border-color:var(--blue); color:var(--blue); }
.pill.active { background:var(--blue); color:#fff; border-color:var(--blue); }

/* ── Misc ────────────────────────────────────────── */
.link { color:var(--blue); text-decoration:none; font-weight:500; }
.link:hover { text-decoration:underline; }
.empty { text-align:center; padding:56px 24px; color:var(--text3); }
.empty h3 { font-size:14px; font-weight:600; color:var(--text2); margin-bottom:6px; }
.empty p { font-size:13px; }
.alert { padding:10px 14px; border-radius:var(--r); font-size:13px; margin-bottom:14px; }
.alert-ok  { background:var(--green-l); color:var(--green-d); }
.alert-err { background:var(--red-l);   color:var(--red-d); }
.va { background:#FEE2E2; color:#991B1B; padding:2px 6px; border-radius:4px; font-family:var(--mono); font-size:12px; }
.vb { background:#DCFCE7; color:#166534; padding:2px 6px; border-radius:4px; font-family:var(--mono); font-size:12px; }
.divider { height:1px; background:var(--border); margin:20px 0; }
svg { display:block; }
</style>
{% block head %}{% endblock %}
</head>
<body>
<div class="layout">

<aside class="sidebar">
  <div class="sb-logo">
    <div class="sb-mark">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
    </div>
    <span class="sb-name">recon</span>
  </div>

  <nav class="sb-nav">
    <div class="sb-section">Workspace</div>
    <a href="/" class="nav-item {% if active=='compare' %}active{% endif %}">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><path d="M7 11v4"/><path d="M17 11v4"/><path d="M5 19h4"/><path d="M15 19h4"/></svg>
      Compare
    </a>
    <a href="/batch" class="nav-item {% if active=='batch' %}active{% endif %}">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
      Batch
    </a>
    <div class="sb-section">Records</div>
    <a href="/runs" class="nav-item {% if active=='runs' or active=='run' %}active{% endif %}">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      Run history
    </a>
  </nav>

  <div class="sb-foot">
    <div class="sb-user">
      <div class="sb-avatar">{{ (user or 'U')[0]|upper }}</div>
      <span class="sb-uname">{{ user or '' }}</span>
    </div>
    <a href="/logout" class="sb-logout">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Sign out
    </a>
  </div>
</aside>

<main class="main">
  {% block content %}{% endblock %}
</main>

</div>
</body>
</html>
