<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>recon · break #{{ brk.id }}</title>
<style>
  body { font-family: -apple-system, "Segoe UI", Helvetica, Arial, sans-serif; margin: 0; color: #1f2328; }
  .nav { background: #fff; border-bottom: 1px solid #d1d9e0; padding: 10px 24px; display: flex; align-items: center; gap: 20px; }
  .nav a { color: #1f2328; text-decoration: none; font-size: 14px; }
  .nav a:hover { color: #0969da; }
  .nav .brand { font-weight: 700; font-size: 16px; }
  .nav .logout { margin-left: auto; color: #59636e; }
  .content { padding: 24px; max-width: 640px; }
  h1 { font-size: 20px; margin: 0 0 6px; }
  .meta { color: #59636e; font-size: 13px; margin-bottom: 24px; }
  dl { display: grid; grid-template-columns: 140px 1fr; gap: 6px 12px; font-size: 13px; margin-bottom: 24px; }
  dt { font-weight: 600; color: #59636e; }
  dd { margin: 0; }
  .val-a { background: #ffebe9; padding: 2px 6px; border-radius: 4px; }
  .val-b { background: #dafbe1; padding: 2px 6px; border-radius: 4px; }
  label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 4px; margin-top: 14px; }
  select, input[type=text], textarea { width: 100%; box-sizing: border-box; border: 1px solid #d1d9e0; border-radius: 6px; padding: 7px 10px; font-size: 14px; }
  textarea { resize: vertical; min-height: 80px; }
  .actions { display: flex; gap: 10px; margin-top: 18px; flex-wrap: wrap; }
  button { border: none; border-radius: 6px; padding: 7px 18px; font-size: 14px; font-weight: 600; cursor: pointer; }
  .btn-resolve { background: #1f883d; color: #fff; }
  .btn-fp { background: #59636e; color: #fff; }
  .btn-reopen { background: #f0f0f0; color: #1f2328; }
  a { color: #0969da; }
  .success { background: #dafbe1; color: #116329; border-radius: 6px; padding: 10px 14px; margin-bottom: 18px; font-size: 13px; }
</style>
</head>
<body>
<nav class="nav">
  <span class="brand">recon</span>
  <a href="/">Compare</a>
  <a href="/batch">Batch</a>
  <a href="/runs">History</a>
  <a href="/logout" class="logout">Sign out ({{ user }})</a>
</nav>
<div class="content">
  <div style="margin-bottom:10px"><a href="/runs/{{ brk.run_id }}">← Run #{{ brk.run_id }}</a></div>
  <h1>Break #{{ brk.id }}</h1>
  <div class="meta">Run #{{ brk.run_id }} &nbsp;·&nbsp; {{ brk.break_type.replace('_', ' ') }}</div>

  {% if saved %}<div class="success">Break updated.</div>{% endif %}

  <dl>
    <dt>Key</dt><dd>{{ brk.key_display }}</dd>
    <dt>Column</dt><dd>{{ brk.column or '—' }}</dd>
    {% if brk.a_value is not none %}<dt>A value</dt><dd><span class="val-a">{{ brk.a_value }}</span></dd>{% endif %}
    {% if brk.b_value is not none %}<dt>B value</dt><dd><span class="val-b">{{ brk.b_value }}</span></dd>{% endif %}
    <dt>Status</dt><dd>{{ brk.status.replace('_', ' ') }}</dd>
    <dt>Assigned to</dt><dd>{{ brk.assigned_to or '—' }}</dd>
    <dt>Note</dt><dd>{{ brk.note or '—' }}</dd>
    {% if brk.resolved_at %}<dt>Resolved at</dt><dd>{{ brk.resolved_at }}</dd>{% endif %}
  </dl>

  <form method="post">
    <label>Assign to</label>
    <input type="text" name="assigned_to" value="{{ brk.assigned_to or '' }}" placeholder="username">

    <label>Note</label>
    <textarea name="note" placeholder="Add a note…">{{ brk.note or '' }}</textarea>

    <div class="actions">
      {% if brk.status != 'resolved' %}
      <button type="submit" name="status" value="resolved" class="btn-resolve">Mark resolved</button>
      {% endif %}
      {% if brk.status != 'false_positive' %}
      <button type="submit" name="status" value="false_positive" class="btn-fp">Mark false positive</button>
      {% endif %}
      {% if brk.status != 'open' %}
      <button type="submit" name="status" value="open" class="btn-reopen">Reopen</button>
      {% endif %}
    </div>
  </form>
</div>
</body>
</html>
