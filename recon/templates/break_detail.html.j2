{% extends "_base.html.j2" %}
{% block title %}Break #{{ brk.id }}{% endblock %}

{% block content %}
<div class="top-bar">
  <div class="breadcrumb">
    <a href="/runs">Run history</a>
    <span class="sep">/</span>
    <a href="/runs/{{ brk.run_id }}">Run #{{ brk.run_id }}</a>
    <span class="sep">/</span>
    <span class="cur">Break #{{ brk.id }}</span>
  </div>
</div>

<div class="content" style="max-width:700px;">
  <div class="ph">
    <div class="ph-left">
      <h1>Break #{{ brk.id }}</h1>
      <div class="sub">
        <span class="badge bt-{{ brk.break_type }}">{{ brk.break_type.replace('_', ' ') }}</span>
        &nbsp;·&nbsp; Run #{{ brk.run_id }}
      </div>
    </div>
  </div>

  {% if saved %}
  <div class="alert alert-ok">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:6px;"><polyline points="20 6 9 17 4 12"/></svg>
    Break updated successfully.
  </div>
  {% endif %}

  <div class="card" style="margin-bottom:20px;">
    <div class="card-head"><span class="card-title">Break details</span></div>
    <div class="card-body" style="padding:0;">
      <dl style="display:grid;grid-template-columns:140px 1fr;gap:0;font-size:13.5px;">
        <div style="display:contents;">
          <dt style="padding:11px 20px;color:var(--text3);font-weight:500;border-bottom:1px solid var(--border);background:var(--surface2);">Key</dt>
          <dd style="padding:11px 20px;border-bottom:1px solid var(--border);font-family:var(--mono);font-size:12.5px;">{{ brk.key_display }}</dd>
        </div>
        {% if brk.column %}
        <div style="display:contents;">
          <dt style="padding:11px 20px;color:var(--text3);font-weight:500;border-bottom:1px solid var(--border);background:var(--surface2);">Column</dt>
          <dd style="padding:11px 20px;border-bottom:1px solid var(--border);font-family:var(--mono);font-size:12.5px;">{{ brk.column }}</dd>
        </div>
        {% endif %}
        {% if brk.a_value is not none %}
        <div style="display:contents;">
          <dt style="padding:11px 20px;color:var(--text3);font-weight:500;border-bottom:1px solid var(--border);background:var(--surface2);">A value</dt>
          <dd style="padding:11px 20px;border-bottom:1px solid var(--border);"><span class="va">{{ brk.a_value }}</span></dd>
        </div>
        {% endif %}
        {% if brk.b_value is not none %}
        <div style="display:contents;">
          <dt style="padding:11px 20px;color:var(--text3);font-weight:500;border-bottom:1px solid var(--border);background:var(--surface2);">B value</dt>
          <dd style="padding:11px 20px;border-bottom:1px solid var(--border);"><span class="vb">{{ brk.b_value }}</span></dd>
        </div>
        {% endif %}
        <div style="display:contents;">
          <dt style="padding:11px 20px;color:var(--text3);font-weight:500;border-bottom:1px solid var(--border);background:var(--surface2);">Status</dt>
          <dd style="padding:11px 20px;border-bottom:1px solid var(--border);" class="bs-{{ brk.status }}">{{ brk.status.replace('_', ' ') }}</dd>
        </div>
        <div style="display:contents;">
          <dt style="padding:11px 20px;color:var(--text3);font-weight:500;{% if not brk.resolved_at %}border-bottom:1px solid var(--border);{% endif %}background:var(--surface2);">Assigned to</dt>
          <dd style="padding:11px 20px;{% if not brk.resolved_at %}border-bottom:1px solid var(--border);{% endif %}">{{ brk.assigned_to or '<span style="color:var(--text3);">Unassigned</span>' }}</dd>
        </div>
        {% if brk.resolved_at %}
        <div style="display:contents;">
          <dt style="padding:11px 20px;color:var(--text3);font-weight:500;background:var(--surface2);">Resolved at</dt>
          <dd style="padding:11px 20px;">{{ brk.resolved_at }}</dd>
        </div>
        {% endif %}
      </dl>
    </div>
  </div>

  <div class="card">
    <div class="card-head"><span class="card-title">Update break</span></div>
    <div class="card-body">
      <form method="post">
        <div class="fg">
          <label class="fl" for="assigned">Assign to</label>
          <input id="assigned" type="text" name="assigned_to" value="{{ brk.assigned_to or '' }}" placeholder="Username">
        </div>
        <div class="fg">
          <label class="fl" for="note">Note</label>
          <textarea id="note" name="note" placeholder="Add a note or explanation…">{{ brk.note or '' }}</textarea>
        </div>

        <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:4px;">
          {% if brk.status != 'resolved' %}
          <button type="submit" name="status" value="resolved" class="btn btn-success">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Mark resolved
          </button>
          {% endif %}
          {% if brk.status != 'false_positive' %}
          <button type="submit" name="status" value="false_positive" class="btn btn-ghost">
            Mark false positive
          </button>
          {% endif %}
          {% if brk.status != 'open' %}
          <button type="submit" name="status" value="open" class="btn btn-ghost">
            Reopen
          </button>
          {% endif %}
          <button type="submit" name="status" value="{{ brk.status }}" class="btn btn-ghost" style="margin-left:auto;">
            Save note
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}
