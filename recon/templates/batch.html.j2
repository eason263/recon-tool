{% extends "_base.html.j2" %}
{% block title %}Batch{% endblock %}

{% block content %}
<div class="top-bar">
  <div class="breadcrumb">
    <span class="cur">Batch reconciliation</span>
  </div>
  <div class="top-bar-right">
    <a href="/batch/template" class="btn btn-ghost btn-sm" download>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download template
    </a>
    <a href="/" class="btn btn-ghost btn-sm">Single compare</a>
  </div>
</div>

<div class="content" style="max-width:940px;">
  <div class="ph">
    <div class="ph-left">
      <h1>Batch reconciliation</h1>
      <div class="sub">Enter source/target file paths (server-side paths). For large batches, upload a manifest CSV/XLSX to auto-fill all rows at once.</div>
    </div>
  </div>

  {% if error %}
  <div class="alert alert-err">{{ error }}</div>
  {% endif %}

  <!-- ── Bulk import ── -->
  <div class="card" style="margin-bottom:16px;">
    <div class="card-head">
      <span class="card-title">Bulk import from manifest</span>
      <span style="font-size:12px;color:var(--text3);">Two columns: <code style="font-size:11px;background:var(--surface2);padding:1px 5px;border-radius:3px;">source, target</code> — CSV or XLSX</span>
    </div>
    <div class="card-body" style="padding:14px 20px;">
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
        <input type="file" id="manifest-file" accept=".csv,.xlsx"
               style="flex:1;min-width:200px;max-width:420px;padding:6px 10px;border:1px solid var(--border);border-radius:var(--r);font-size:13px;font-family:var(--font);cursor:pointer;">
        <button type="button" id="load-manifest" class="btn btn-ghost">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Load pairs
        </button>
        <span id="manifest-status" style="font-size:13px;"></span>
      </div>
    </div>
  </div>

  <!-- ── Pairs table ── -->
  <div class="card">
    <div class="card-head">
      <span class="card-title">File pairs</span>
      <span id="pair-count" style="font-size:12px;color:var(--text3);"></span>
    </div>

    <form method="post" action="/batch" id="batch-form">
      <div style="overflow-x:auto;">
        <table id="pairs" style="border-radius:0;box-shadow:none;border:none;">
          <thead>
            <tr>
              <th style="width:40px;text-align:right;">#</th>
              <th>Source file path</th>
              <th>Target file path</th>
              <th style="width:36px;"></th>
            </tr>
          </thead>
          <tbody>
            {% for s, t in form_rows or [("", ""), ("", ""), ("", "")] %}
            <tr>
              <td class="idx" style="text-align:right;color:var(--text3);font-size:12px;width:40px;padding:6px 10px;"></td>
              <td style="padding:4px 8px;">
                <input type="text" name="source" value="{{ s }}" placeholder="/absolute/path/to/source.csv"
                       style="border:none;box-shadow:none;padding:7px 8px;font-size:13px;font-family:var(--mono);">
              </td>
              <td style="padding:4px 8px;">
                <input type="text" name="target" value="{{ t }}" placeholder="/absolute/path/to/target.csv"
                       style="border:none;box-shadow:none;padding:7px 8px;font-size:13px;font-family:var(--mono);">
              </td>
              <td style="text-align:center;padding:4px 6px;">
                <button type="button" class="del" title="Remove"
                        style="border:none;background:none;color:var(--text3);cursor:pointer;font-size:18px;padding:2px 6px;border-radius:4px;line-height:1;"
                        onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text3)'">×</button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div style="padding:10px 16px;border-top:1px solid var(--border);display:flex;align-items:center;gap:10px;">
        <button type="button" id="add-row" class="btn btn-ghost btn-sm">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add row
        </button>
        <button type="button" id="clear-rows" class="btn btn-ghost btn-sm" style="color:var(--text3);">Clear all</button>
      </div>

      <div style="padding:0 20px 20px;">
        <fieldset class="fieldset">
          <legend>Options — applied to every pair</legend>
          <div class="fg" style="margin-top:10px;">
            <label class="fl" for="key">Key column(s)</label>
            <input id="key" type="text" name="key" placeholder="e.g. trade_id" value="{{ form.get('key', '') }}">
            <div class="fh">For CSV/XLSX pairs. Leave empty for a text diff.</div>
          </div>
          <div style="display:flex;gap:16px;flex-wrap:wrap;">
            <div class="fg" style="flex:1;min-width:180px;">
              <label class="fl" for="ignore">Ignore columns</label>
              <input id="ignore" type="text" name="ignore" placeholder="e.g. updated_at" value="{{ form.get('ignore', '') }}">
            </div>
            <div class="fg" style="max-width:160px;">
              <label class="fl" for="tol">Numeric tolerance</label>
              <input id="tol" type="number" name="tolerance" step="any" min="0" placeholder="0" value="{{ form.get('tolerance', '') }}">
            </div>
          </div>
          <label class="check-row">
            <input type="checkbox" name="show_matched" value="1" {% if form.get('show_matched') %}checked{% endif %}>
            Show all fields of mismatched records in detail reports
          </label>
        </fieldset>

        <button class="btn btn-primary" type="submit">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          Run batch
        </button>
      </div>
    </form>
  </div>
</div>

<script>
const tbody = document.querySelector("#pairs tbody");

function makeRow(src, tgt) {
  const tr = document.createElement("tr");
  tr.innerHTML = `
    <td class="idx" style="text-align:right;color:var(--text3);font-size:12px;width:40px;padding:6px 10px;"></td>
    <td style="padding:4px 8px;">
      <input type="text" name="source" value="${esc(src)}" placeholder="/absolute/path/to/source.csv"
             style="border:none;box-shadow:none;padding:7px 8px;font-size:13px;font-family:var(--mono);width:100%;">
    </td>
    <td style="padding:4px 8px;">
      <input type="text" name="target" value="${esc(tgt)}" placeholder="/absolute/path/to/target.csv"
             style="border:none;box-shadow:none;padding:7px 8px;font-size:13px;font-family:var(--mono);width:100%;">
    </td>
    <td style="text-align:center;padding:4px 6px;">
      <button type="button" class="del" title="Remove"
              style="border:none;background:none;color:var(--text3);cursor:pointer;font-size:18px;padding:2px 6px;border-radius:4px;line-height:1;"
              onmouseover="this.style.color='var(--red)'" onmouseout="this.style.color='var(--text3)'">×</button>
    </td>`;
  tr.querySelector(".del").addEventListener("click", () => {
    if (tbody.querySelectorAll("tr").length > 1) { tr.remove(); renumber(); }
  });
  return tr;
}

function esc(s) {
  return (s || "").replace(/&/g,"&amp;").replace(/"/g,"&quot;").replace(/</g,"&lt;");
}

function renumber() {
  tbody.querySelectorAll("tr").forEach((tr, i) => {
    const cell = tr.querySelector(".idx");
    if (cell) cell.textContent = i + 1;
  });
  const n = tbody.querySelectorAll("tr").length;
  document.getElementById("pair-count").textContent = n + (n === 1 ? " pair" : " pairs");
}

function bindExistingDeletes() {
  tbody.querySelectorAll(".del").forEach(btn => {
    btn.addEventListener("click", () => {
      if (tbody.querySelectorAll("tr").length > 1) { btn.closest("tr").remove(); renumber(); }
    });
  });
}

document.getElementById("add-row").addEventListener("click", () => {
  tbody.appendChild(makeRow("", ""));
  renumber();
  tbody.lastElementChild.querySelector("input").focus();
});

document.getElementById("clear-rows").addEventListener("click", () => {
  if (!confirm("Clear all rows?")) return;
  tbody.innerHTML = "";
  tbody.appendChild(makeRow("", ""));
  renumber();
});

// ── Manifest upload ──────────────────────────────────────────────
document.getElementById("load-manifest").addEventListener("click", async () => {
  const fileInput = document.getElementById("manifest-file");
  const status = document.getElementById("manifest-status");
  if (!fileInput.files.length) {
    status.textContent = "Please select a manifest file first.";
    status.style.color = "var(--red)";
    return;
  }
  status.textContent = "Loading…";
  status.style.color = "var(--text3)";

  const fd = new FormData();
  fd.append("manifest", fileInput.files[0]);

  try {
    const resp = await fetch("/batch/load-manifest", { method: "POST", body: fd });
    const data = await resp.json();
    if (data.error) {
      status.textContent = "Error: " + data.error;
      status.style.color = "var(--red)";
      return;
    }
    // Replace table contents with loaded pairs
    tbody.innerHTML = "";
    data.pairs.forEach(p => tbody.appendChild(makeRow(p.source, p.target)));
    // Keep at least one blank row if empty
    if (!data.pairs.length) tbody.appendChild(makeRow("", ""));
    renumber();
    status.textContent = `✓ Loaded ${data.pairs.length} pairs`;
    status.style.color = "var(--green)";
    fileInput.value = "";
  } catch (err) {
    status.textContent = "Network error — try again.";
    status.style.color = "var(--red)";
  }
});

bindExistingDeletes();
renumber();
</script>
{% endblock %}
