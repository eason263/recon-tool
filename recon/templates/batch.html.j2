{% extends "_base.html.j2" %}
{% block title %}Batch{% endblock %}

{% block head %}
<style>
.drop-zone {
  border: 2px dashed var(--border2);
  border-radius: var(--r);
  background: var(--surface2);
  transition: border-color 150ms, background 150ms;
  cursor: pointer;
  position: relative;
}
.drop-zone:hover, .drop-zone.drag-over {
  border-color: var(--blue);
  background: var(--blue-l);
}
.drop-zone input[type=file] {
  position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
  border: none; box-shadow: none; background: none; padding: 0;
}
.drop-zone .dz-inner {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 4px; padding: 10px 8px; pointer-events: none;
}
.drop-zone .dz-icon { color: var(--text3); }
.drop-zone .dz-label { font-size: 12px; font-weight: 500; color: var(--text2); text-align: center; }
.drop-zone .dz-hint { font-size: 11px; color: var(--text3); }
.drop-zone .dz-chosen { font-size: 12px; font-weight: 600; color: var(--blue); word-break: break-all; text-align: center; }
.pair-row td { vertical-align: top; }
</style>
{% endblock %}

{% block content %}
<div class="top-bar">
  <div class="breadcrumb">
    <span class="cur">Batch reconciliation</span>
  </div>
  <div class="top-bar-right">
    <a href="/batch/template" class="btn btn-ghost btn-sm" download>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Download template
    </a>
    <a href="/" class="btn btn-ghost btn-sm">Single compare</a>
  </div>
</div>

<div class="content" style="max-width:960px;">
  <div class="ph">
    <div class="ph-left">
      <h1>Batch reconciliation</h1>
      <div class="sub">Upload source and target file pairs (CSV or XLSX). Options apply to every pair. For CLI use: <code style="font-family:monospace;font-size:12px;background:#F1F5F9;padding:1px 5px;border-radius:3px;">recon batch manifest.xlsx</code></div>
    </div>
  </div>

  {% if error %}
  <div class="alert alert-err">{{ error }}</div>
  {% endif %}

  <div class="card">
    <div class="card-head">
      <span class="card-title">File pairs</span>
      <span style="font-size:12px;color:var(--text3);">CSV and XLSX supported</span>
    </div>

    <form method="post" action="/batch" enctype="multipart/form-data" id="batch-form">
      <div style="overflow-x:auto;">
        <table id="pairs-table" style="border-radius:0;box-shadow:none;border:none;">
          <thead>
            <tr>
              <th style="width:36px;text-align:center;">#</th>
              <th>Source file</th>
              <th>Target file</th>
              <th style="width:40px;"></th>
            </tr>
          </thead>
          <tbody id="pairs-body">
            <!-- rows injected by JS -->
          </tbody>
        </table>
      </div>

      <div style="padding:12px 20px;border-top:1px solid var(--border);">
        <button type="button" id="add-row" class="btn btn-ghost btn-sm">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add pair
        </button>
      </div>

      <div style="padding:0 20px 20px;">
        <fieldset class="fieldset">
          <legend>Options — applied to every pair</legend>
          <div class="fg" style="margin-top:10px;">
            <label class="fl" for="key">Key column(s)</label>
            <input id="key" type="text" name="key" placeholder="e.g. trade_id" value="{{ form.get('key', '') }}">
            <div class="fh">For CSV/XLSX pairs. Leave empty for a text diff.</div>
          </div>
          <div style="display:flex;gap:16px;flex-wrap:wrap;">
            <div class="fg" style="flex:1;min-width:180px;">
              <label class="fl" for="ignore">Ignore columns</label>
              <input id="ignore" type="text" name="ignore" placeholder="e.g. updated_at" value="{{ form.get('ignore', '') }}">
            </div>
            <div class="fg" style="max-width:160px;">
              <label class="fl" for="tol">Numeric tolerance</label>
              <input id="tol" type="number" name="tolerance" step="any" min="0" placeholder="0" value="{{ form.get('tolerance', '') }}">
            </div>
          </div>
          <label class="check-row">
            <input type="checkbox" name="show_matched" value="1" {% if form.get('show_matched') %}checked{% endif %}>
            Show all fields of mismatched records in detail reports
          </label>
        </fieldset>

        <button class="btn btn-primary" type="submit" id="submit-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          Run batch
        </button>
      </div>
    </form>
  </div>
</div>

<script>
const tbody = document.getElementById("pairs-body");
const INIT_ROWS = 3;

function makeDropZone(name) {
  const wrap = document.createElement("div");
  wrap.className = "drop-zone";
  wrap.innerHTML = `
    <input type="file" name="${name}" accept=".csv,.xlsx">
    <div class="dz-inner">
      <svg class="dz-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      <span class="dz-label">Click to upload</span>
      <span class="dz-hint">CSV or XLSX</span>
    </div>`;

  const inp = wrap.querySelector("input");
  inp.addEventListener("change", () => {
    const inner = wrap.querySelector(".dz-inner");
    if (inp.files.length) {
      inner.innerHTML = `<span class="dz-chosen">${inp.files[0].name}</span>`;
    } else {
      inner.innerHTML = `
        <svg class="dz-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <span class="dz-label">Click to upload</span>
        <span class="dz-hint">CSV or XLSX</span>`;
    }
  });

  ["dragenter","dragover"].forEach(ev => {
    wrap.addEventListener(ev, e => { e.preventDefault(); wrap.classList.add("drag-over"); });
  });
  ["dragleave","drop"].forEach(ev => {
    wrap.addEventListener(ev, () => wrap.classList.remove("drag-over"));
  });

  return wrap;
}

function renumber() {
  tbody.querySelectorAll(".pair-row").forEach((tr, i) => {
    tr.querySelector(".row-num").textContent = i + 1;
  });
}

function addRow() {
  const tr = document.createElement("tr");
  tr.className = "pair-row";

  const idxTd = document.createElement("td");
  idxTd.style.cssText = "text-align:center;color:var(--text3);font-size:12px;padding:8px 4px;";
  idxTd.innerHTML = `<span class="row-num"></span>`;

  const srcTd = document.createElement("td");
  srcTd.style.cssText = "padding:8px 12px;";
  srcTd.appendChild(makeDropZone("source"));

  const tgtTd = document.createElement("td");
  tgtTd.style.cssText = "padding:8px 12px;";
  tgtTd.appendChild(makeDropZone("target"));

  const delTd = document.createElement("td");
  delTd.style.cssText = "text-align:center;padding:8px 4px;";
  const delBtn = document.createElement("button");
  delBtn.type = "button";
  delBtn.title = "Remove row";
  delBtn.style.cssText = "border:none;background:none;color:var(--text3);cursor:pointer;font-size:18px;padding:4px 8px;border-radius:4px;line-height:1;";
  delBtn.textContent = "×";
  delBtn.onmouseover = () => delBtn.style.color = "var(--red)";
  delBtn.onmouseout  = () => delBtn.style.color = "var(--text3)";
  delBtn.addEventListener("click", () => {
    if (tbody.querySelectorAll(".pair-row").length > 1) {
      tr.remove();
      renumber();
    }
  });
  delTd.appendChild(delBtn);

  tr.append(idxTd, srcTd, tgtTd, delTd);
  tbody.appendChild(tr);
  renumber();
}

// Initialise table
for (let i = 0; i < INIT_ROWS; i++) addRow();
document.getElementById("add-row").addEventListener("click", () => { addRow(); });

// Validate before submit
document.getElementById("batch-form").addEventListener("submit", function(e) {
  const rows = tbody.querySelectorAll(".pair-row");
  let hasAtLeastOne = false;
  for (const row of rows) {
    const inputs = row.querySelectorAll("input[type=file]");
    const srcOk = inputs[0].files.length > 0;
    const tgtOk = inputs[1].files.length > 0;
    if (srcOk && tgtOk) { hasAtLeastOne = true; continue; }
    if (srcOk !== tgtOk) {
      e.preventDefault();
      alert("Each row needs both a source and a target file.");
      return;
    }
  }
  if (!hasAtLeastOne) {
    e.preventDefault();
    alert("Please upload at least one source/target pair.");
  }
});
</script>
{% endblock %}
